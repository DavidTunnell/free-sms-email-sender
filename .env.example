# Required — Brevo API key
# Get yours: Brevo dashboard → Settings → SMTP & API → API Keys → Generate
BREVO_API_KEY=your-brevo-api-key-here

# Optional — For test mode (menu option 6): send to yourself first
# Fill these in to test email/SMS delivery before the full campaign
TEST_EMAIL=your@email.com
TEST_PHONE=+12105551234
TEST_FIRST_NAME=YourName
